# Database
MONGODB_URI=mongodb://localhost:27017/sewaconnect

# Auth
JWT_ACCESS_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_a_different_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# MFA (TOTP)
MFA_ISSUER=SewaConnect

# Field-level encryption (verification docs, sensitive profile fields)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_32_byte_hex_key

# Payments (sandbox credentials only — never commit real merchant keys)
ESEWA_MERCHANT_ID=your_sandbox_merchant_id
ESEWA_SECRET_KEY=your_sandbox_secret_key
KHALTI_SECRET_KEY=your_sandbox_secret_key

# Rate limiting (if using Redis-backed limiter instead of in-memory)
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
