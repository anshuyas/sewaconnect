# Payments (sandbox credentials only — never commit real merchant keys)
ESEWA_MERCHANT_ID=your_sandbox_merchant_id
ESEWA_SECRET_KEY=your_sandbox_secret_key
KHALTI_SECRET_KEY=your_sandbox_secret_key

# Rate limiting (if using Redis-backed limiter instead of in-memory)
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
